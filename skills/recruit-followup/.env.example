# recruit-followup 配置模板
# 复制本文件为 .env，填入你自己的值。.env 不会进 git（已在 .gitignore）。
#
# ⚠️ 安全提醒：
#   - 飞书 App Secret 是高敏感凭证，泄露后任何人都能以你的应用身份调飞书 API
#   - 不要把 .env 提交到 git，不要发到聊天群
#   - 怀疑泄露立即去飞书开放平台重置 Secret

# 飞书招聘应用凭证（在 https://open.feishu.cn/app/<你的AppID>/security 获取）
LARK_APP_ID=
LARK_APP_SECRET=

# lark-cli 可执行文件路径（留空则假定在 PATH）
LARK_CLI_PATH=

# 项目根目录（岗位缓存、录入速查等 notes 文件所在）
PROJECT_ROOT=

# 简历下载默认落点（留空则用 ~/Downloads）
DOWNLOAD_DIR=

# 飞书多维表格（Bitable）—— 跟踪表 / 候选人主库
# 在多维表格 URL 里取：https://xxx.feishu.cn/base/<BASE_TOKEN>
TRACKING_BASE_TOKEN=
TRACKING_TABLE_ID=         # 招聘跟踪表 ID
CANDIDATE_TABLE_ID=        # 候选人主库表 ID

# 招聘沟通群 chat_id（在群设置里获取，用于扫邀约信号）
# 多个用英文逗号分隔
RECRUIT_CHAT_IDS=
