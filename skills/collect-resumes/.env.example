# collect-resumes 配置模板
# 复制本文件为 .env，填入你自己的值。.env 不会进 git（已在 .gitignore）。

# lark-cli 可执行文件路径（npm 全局安装后的位置）
# Windows:  C:/Users/<你的用户名>/AppData/Roaming/npm/lark-cli.cmd
# macOS:    /opt/homebrew/bin/lark-cli  或  /usr/local/bin/lark-cli
LARK_CLI_PATH=

# 归档根目录（简历按团队/岗位组织在这个目录下）
# 示例: /Users/yourname/Documents/resumes  或  D:/resumes
ARCHIVE_ROOT=

# 用户下载目录（浏览器/脚本默认下载落点）
# 留空则用系统默认 ~/Downloads
DOWNLOAD_DIR=

# 扫描结果输出路径（scan_all.mjs 全量数据落盘位置）
# 留空则用 <skill>/notes/_scan_all.json
SCAN_OUTPUT=
